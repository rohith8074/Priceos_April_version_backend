# ── MongoDB ──────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb://localhost:27017/priceos
DATABASE_NAME=priceos

# ── JWT Auth ─────────────────────────────────────────────────
# Secret for signing access tokens
JWT_SECRET=your_32_character_jwt_secret_here
# Secret for signing refresh tokens
JWT_REFRESH_SECRET=your_32_character_refresh_secret_here

# ── PMS Configuration ────────────────────────────────────────
# mode: 'db' (cached) or 'api' (live)
HOSTAWAY_MODE=db
Hostaway_Account_ID=your_account_id
Hostaway_API_Key=your_api_key
Hostaway_Authorization_token=your_auth_token

# ── Lyzr AI Configuration ────────────────────────────────────
LYZR_API_KEY=your_lyzr_api_key
LYZR_API_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/
LYZR_STREAM_URL=https://agent-prod.studio.lyzr.ai/v3/inference/stream/

# Agent IDs from Lyzr Studio
AGENT_ID=your_main_agent_id
LYZR_CONTEXT_ID=your_shared_context_id
Marketing_Agent_ID=your_marketing_agent_id
LYZR_Conversation_Summary_Agent_ID=your_summary_agent_id
LYZR_Chat_Response_Agent_ID=your_chat_agent_id
LYZR_Competitor_Benchmark_Agent_ID=your_benchmark_agent_id
LYZR_DASHBOARD_AGENT_ID=your_dashboard_agent_id
Lyzr_Guardrail_Agent_for_Floor_Ceiling_Values=your_guardrail_agent_id

# ── Backend URLs ─────────────────────────────────────────────
# Local or production URL for agent API callbacks
PYTHON_BACKEND_URL=http://localhost:8000

# ── Third Party APIs ─────────────────────────────────────────
TICKETMASTER_API_KEY=your_ticketmaster_key
EVENTBRITE_API_KEY=your_eventbrite_key
# Airbtics (STR Market Intelligence)
AIRBTICS_API_KEY=your_airbtics_key
AIRBTICS_DUBAI_MARKET_ID=2286

# ── Security ─────────────────────────────────────────────────
# Shared secret for agent tool authorization
AGENT_TOOLS_JWT_SECRET=your_shared_agent_tool_secret
